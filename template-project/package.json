{
  "name": "bda-template-project",
  "version": "0.1.0",
  "private": true,
  "description": "Starter template for Product Knowledge as Code architecture",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "verify:sync": "node scripts/verify-sync.js",
    "generate:tests": "npm run verify:sync && node scripts/generate-tests.js && node scripts/generate-api-tests.js",
    "generate:md-tests": "node scripts/generate-md-tests.js",
    "analyze:pr-impact": "node scripts/pr-impact-analyzer.js --input scripts/pr-impact-input.json",
    "simulate:closed-loop": "node scripts/closed-loop-simulator.js --input scripts/closed-loop-input.json",
    "verify:coverage": "node scripts/rule-coverage.js",
    "simulate:impact": "node scripts/simulate-pr-impact.js scripts/mock-pr-diff.txt",
    "simulate:knowledge-update": "node scripts/simulate-knowledge-update.js docs/last-impact-report.json",
    "demo:execute": "node scripts/mock-test-execution.js",
    "demo:flow": "npm run simulate:impact && npm run simulate:knowledge-update && npm run generate:md-tests && npm run demo:execute",
    "test:api": "npx playwright test --config=playwright.api.config.ts",
    "test:ui": "npx playwright test",
    "test": "npm run test:api && npm run test:ui",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.54.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
